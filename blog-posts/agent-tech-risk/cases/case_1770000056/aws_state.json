            "to_port": 5432,
            "cidr_blocks": ["0.0.0.0/0"]
          }
        ]
      }
    ],
    "vpcs": [
      {
        "vpc_id": "vpc-12345678",
        "cidr_block": "10.0.0.0/16",
        "state": "available",
        "tags": {
          "Name": "PayFlow-Production-VPC"
        }
      },
      {
        "vpc_id": "vpc-87654321",
        "cidr_block": "10.1.0.0/16",
        "state": "available",
        "tags": {
          "Name": "PayFlow-Development-VPC"
        }
      }
    ]
  },
  "rds": {
    "instances": [
      {
        "db_instance_identifier": "payflow-prod-db",
        "db_instance_class": "db.t3.medium",
        "engine": "postgres",
        "engine_version": "13.7",
        "publicly_accessible": true,
        "vpc_id": "vpc-12345678",
        "db_subnet_group_name": "payflow-prod-subnet-group",
        "vpc_security_groups": ["sg-rds12345"],
        "tags": {
          "Name": "PayFlow-Production-DB",
          "Environment": "production"
        }
      },
      {
        "db_instance_identifier": "payflow-dev-db",
        "db_instance_class": "db.t3.small",
        "engine": "postgres",
        "engine_version": "13.7",
        "publicly_accessible": false,
        "vpc_id": "vpc-87654321",
        "db_subnet_group_name": "payflow-dev-subnet-group",
        "vpc_security_groups": ["sg-rds12345"],
        "tags": {
          "Name": "PayFlow-Development-DB",
          "Environment": "development"
        }
      }
    ]
  },
  "lambda": {
    "functions": [
      {
        "function_name": "payflow-payment-processor",
        "runtime": "python3.9",
        "role": "arn:aws:iam::567890123456:role/PayFlowLambdaRole",
        "timeout": 30,
        "memory_size": 256,
        "environment_variables": {
          "DB_HOST": "payflow-prod-db.cluster-xyz.us-east-1.rds.amazonaws.com",
          "S3_BUCKET": "payflow-api-data"
        }
      },
      {
        "function_name": "payflow-data-sync",
        "runtime": "python3.9",
        "role": "arn:aws:iam::567890123456:role/PayFlowDataRole",
        "timeout": 300,
        "memory_size": 512,
        "environment_variables": {
          "SOURCE_BUCKET": "payflow-api-data",
          "DEST_BUCKET": "payflow-backups"
        }
      },
      {
        "function_name": "payflow-webhook-handler",
        "runtime": "nodejs18.x",
        "role": "arn:aws:iam::567890123456:role/PayFlowLambdaRole",
        "timeout": 15,
        "memory_size": 128,
        "environment_variables": {
          "API_ENDPOINT": "https://api.payflow.com"
        }
      }
    ]
  },
  "eks": {
    "clusters": [],
    "node_groups": []
  }
}