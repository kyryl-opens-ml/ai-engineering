            "cidr_blocks": ["0.0.0.0/0"]
          },
          {
            "ip_protocol": "tcp",
            "from_port": 22,
            "to_port": 22,
            "cidr_blocks": ["10.0.0.0/8"]
          }
        ]
      },
      {
        "group_id": "sg-87654321",
        "group_name": "payflow-web-sg",
        "vpc_id": "vpc-12345678",
        "ingress_rules": [
          {
            "ip_protocol": "tcp",
            "from_port": 443,
            "to_port": 443,
            "cidr_blocks": ["0.0.0.0/0"]
          },
          {
            "ip_protocol": "tcp",
            "from_port": 80,
            "to_port": 80,
            "cidr_blocks": ["0.0.0.0/0"]
          }
        ]
      },
      {
        "group_id": "sg-dev12345",
        "group_name": "payflow-dev-sg",
        "vpc_id": "vpc-87654321",
        "ingress_rules": [
          {
            "ip_protocol": "tcp",
            "from_port": 22,
            "to_port": 22,
            "cidr_blocks": ["0.0.0.0/0"]
          },
          {
            "ip_protocol": "tcp",
