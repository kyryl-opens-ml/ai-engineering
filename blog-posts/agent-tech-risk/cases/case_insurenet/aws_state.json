          "Environment": "shared"
        }
      },
      {
        "Name": "insurenet/prod/stripe",
        "SecretString": "{\"publishable_key\":\"pk_live_xyz789\",\"secret_key\":\"sk_live_abc123\"}",
        "Tags": {
          "Environment": "production"
        }
      }
    ]
  },
  "sqs": {
    "queues": [
      {
        "QueueName": "insurenet-quote-processing",
        "Attributes": {
          "VisibilityTimeout": "300"
        }
      },
      {
        "QueueName": "insurenet-claims-queue",
        "Attributes": {
          "VisibilityTimeout": "60"
        }
      },
      {
        "QueueName": "insurenet-notifications",
        "Attributes": {
          "VisibilityTimeout": "30"
        }
      }
    ]
  }
}