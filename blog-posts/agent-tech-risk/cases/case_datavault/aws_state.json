{
  "iam": {
    "roles": [
      {
        "RoleName": "DataVaultLambdaExecutionRole",
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "lambda.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "AttachedPolicies": ["DataVaultLambdaPolicy"]
      },
      {
        "RoleName": "DataVaultEC2Role",
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "ec2.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "AttachedPolicies": ["DataVaultEC2Policy"]
      },
      {
        "RoleName": "DataVaultK8sServiceRole",
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "eks.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "AttachedPolicies": ["DataVaultK8sPolicy"]
      }
    ],
    "policies": [
      {
        "PolicyName": "DataVaultLambdaPolicy",
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Action": [
                "logs:CreateLogGroup",
                "logs:CreateLogStream",
                "logs:PutLogEvents",
                "dynamodb:PutItem",
                "dynamodb:GetItem",
                "dynamodb:UpdateItem",
                "s3:GetObject",
                "s3:PutObject"
              ],
              "Resource": "*"
            }
          ]
        }
      },
      {
        "PolicyName": "DataVaultEC2Policy",
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Action": [
                "s3:GetObject",
                "s3:PutObject",
                "dynamodb:*",
                "secretsmanager:GetSecretValue"
              ],
              "Resource": "*"
            }
          ]
        }
      },
      {
        "PolicyName": "DataVaultK8sPolicy",
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Action": [
                "s3:*",
                "dynamodb:*",
                "secretsmanager:*"
              ],
              "Resource": "*"
            }
          ]
        }
      }
    ],
    "users": [
      {
        "UserName": "datavault-ci-deploy",
        "AttachedPolicies": ["DataVaultLambdaPolicy"]
      },
      {
        "UserName": "datavault-analytics",
        "AttachedPolicies": ["DataVaultEC2Policy"]
      }
    ]
  },
  "s3": {
    "buckets": [
      {
        "Name": "datavault-prod-customer-data",
        "Versioning": "Suspended",
        "Encryption": "None",
        "PublicAccessBlock": {
          "BlockPublicAcls": true,
          "IgnorePublicAcls": true,
          "BlockPublicPolicy": true,
          "RestrictPublicBuckets": true
        }
      },
      {
        "Name": "datavault-backup-archives",
        "Versioning": "Enabled",
        "Encryption": "SSE-S3",
        "PublicAccessBlock": {
          "BlockPublicAcls": true,
          "IgnorePublicAcls": true,
          "BlockPublicPolicy": true,
          "RestrictPublicBuckets": true
        }
      },
      {
        "Name": "datavault-static-assets",
        "Versioning": "Enabled",
        "Encryption": "AES256",
        "PublicAccessBlock": {
          "BlockPublicAcls": false,
          "IgnorePublicAcls": false,
          "BlockPublicPolicy": false,
          "RestrictPublicBuckets": false
        }
      },
      {
        "Name": "datavault-dev-sandbox",
        "Versioning": "Suspended",
        "Encryption": "AES256",
        "PublicAccessBlock": {
          "BlockPublicAcls": true,
          "IgnorePublicAcls": true,
          "BlockPublicPolicy": true,
          "RestrictPublicBuckets": true
        }
      },
      {
        "Name": "datavault-logs-central",
        "Versioning": "Enabled",
        "Encryption": "SSE-S3",
        "PublicAccessBlock": {
          "BlockPublicAcls": true,
          "IgnorePublicAcls": true,
          "BlockPublicPolicy": true,
          "RestrictPublicBuckets": true
        }
      }
    ]
  },
  "ec2": {
    "instances": [
      {
        "InstanceId": "i-0a1b2c3d4e5f6g7h8",
        "InstanceType": "t3.large",
        "State": "running",
        "Tags": {
          "Name": "datavault-prod-api-01",
          "Environment": "production"
        }
      },
      {
        "InstanceId": "i-9i8h7g6f5e4d3c2b1",
        "InstanceType": "t3.xlarge",
        "State": "running",
        "Tags": {
          "Name": "datavault-prod-worker-01",
          "Environment": "production"
        }
      },
      {
        "InstanceId": "i-1a2b3c4d5e6f7g8h9",
        "InstanceType": "t3.medium",
        "State": "running",
        "Tags": {
          "Name": "datavault-staging-web",
          "Environment": "staging"
        }
      },
      {
        "InstanceId": "i-2b3c4d5e6f7g8h9i0",
        "InstanceType": "t3.small",
        "State": "running",
        "Tags": {
          "Name": "datavault-monitoring",
          "Environment": "production"
        }
      }
    ],
    "security_groups": [
      {
        "GroupName": "datavault-web-sg",
        "Description": "Web tier security group",
        "IngressRules": [
          {
            "IpProtocol": "tcp",
            "FromPort": 443,
            "ToPort": 443,
            "CidrBlocks": ["0.0.0.0/0"]
          },
          {
            "IpProtocol": "tcp",
            "FromPort": 80,
            "ToPort": 80,
            "CidrBlocks": ["0.0.0.0/0"]
          }
        ]
      },
      {
        "GroupName": "datavault-admin-sg",
        "Description": "Administrative access",
        "IngressRules": [
          {
            "IpProtocol": "tcp",
            "FromPort": 22,
            "ToPort": 22,
            "CidrBlocks": ["0.0.0.0/0"]
          },
          {
            "IpProtocol": "tcp",
            "FromPort": 3389,
            "ToPort": 3389,
            "CidrBlocks": ["0.0.0.0/0"]
          }
        ]
      },
      {
        "GroupName": "datavault-db-sg",
        "Description": "Database access",
        "IngressRules": [
          {
            "IpProtocol": "tcp",
            "FromPort": 5432,
            "ToPort": 5432,
            "CidrBlocks": ["10.0.0.0/16"]
          }
        ]
      },
      {
        "GroupName": "datavault-k8s-sg",
        "Description": "Kubernetes cluster access",
        "IngressRules": [
          {
            "IpProtocol": "tcp",
            "FromPort": 6443,
            "ToPort": 6443,
            "CidrBlocks": ["10.0.0.0/16"]
          },
          {
            "IpProtocol": "tcp",
            "FromPort": 10250,
            "ToPort": 10250,
            "CidrBlocks": ["10.0.0.0/16"]
          }
        ]
      }
    ],
    "vpcs": [
      {
        "CidrBlock": "10.0.0.0/16",
        "Tags": {
          "Name": "datavault-prod-vpc"
        }
      },
      {
        "CidrBlock": "10.1.0.0/16",
        "Tags": {
          "Name": "datavault-staging-vpc"
        }
      }
    ]
  },
  "lambda": {
    "functions": [
      {
        "FunctionName": "datavault-user-auth",
        "Runtime": "python3.11",
        "Handler": "auth.handler",
        "MemorySize": 512,
        "Timeout": 30,
        "Role": "arn:aws:iam::123456789012:role/DataVaultLambdaExecutionRole",
        "Environment": {
          "DB_PASSWORD": "prod_db_pass_2023!",
          "JWT_SECRET": "super-secret-jwt-key-12345",
          "API_KEY": "ak-live-1234567890abcdef"
        }
      },
      {
        "FunctionName": "datavault-data-processor",
        "Runtime": "python3.9",
        "Handler": "process.handler",
        "MemorySize": 1024,
        "Timeout": 300,
        "Role": "arn:aws:iam::123456789012:role/DataVaultLambdaExecutionRole",
        "Environment": {
          "S3_BUCKET": "datavault-prod-customer-data",
          "REGION": "us-east-1"
        }
      },
      {
        "FunctionName": "datavault-webhook-handler",
        "Runtime": "nodejs18.x",
        "Handler": "webhook.handler",
        "MemorySize": 256,
        "Timeout": 60,
        "Role": "arn:aws:iam::123456789012:role/DataVaultLambdaExecutionRole",
        "Environment": {
          "STRIPE_SECRET": "sk_live_abcd1234567890",
          "WEBHOOK_SECRET": "whsec_test_12345"
        }
      },
      {
        "FunctionName": "datavault-report-generator",
        "Runtime": "python3.11",
        "Handler": "reports.handler",
        "MemorySize": 2048,
        "Timeout": 600,
        "Role": "arn:aws:iam::123456789012:role/DataVaultLambdaExecutionRole",
        "Environment": {
          "OUTPUT_BUCKET": "datavault-backup-archives"
        }
      }
    ]
  },
  "dynamodb": {
    "tables": [
      {
        "TableName": "datavault-user-sessions",
        "KeySchema": [
          {
            "AttributeName": "session_id",
            "KeyType": "HASH"
          }
        ],
        "AttributeDefinitions": [
          {
            "AttributeName": "session_id",
            "AttributeType": "S"
          }
        ],
        "BillingMode": "PAY_PER_REQUEST",
        "SSESpecification": {
          "Enabled": false
        },
        "PointInTimeRecoveryEnabled": false,
        "Tags": {
          "Environment": "production"
        }
      },
      {
        "TableName": "datavault-customer-data",
        "KeySchema": [
          {
            "AttributeName": "customer_id",
            "KeyType": "HASH"
          }
        ],
        "AttributeDefinitions": [
          {
            "AttributeName": "customer_id",
            "AttributeType": "S"
          }
        ],
        "BillingMode": "PAY_PER_REQUEST",
        "SSESpecification": {
          "Enabled": false
        },
        "PointInTimeRecoveryEnabled": false,
        "Tags": {
          "Environment": "production"
        }
      },
      {
        "TableName": "datavault-audit-logs",
        "KeySchema": [
          {
            "AttributeName": "log_id",
            "KeyType": "HASH"
          }
        ],
        "AttributeDefinitions": [
          {
            "AttributeName": "log_id",
            "AttributeType": "S"
          }
        ],
        "BillingMode": "PAY_PER_REQUEST",
        "SSESpecification": {
          "Enabled": true
        },
        "PointInTimeRecoveryEnabled": true,
        "Tags": {
          "Environment": "production"
        }
      },
      {
        "TableName": "datavault-analytics-cache",
        "KeySchema": [
          {
            "AttributeName": "cache_key",
            "KeyType": "HASH"
          }
        ],
        "AttributeDefinitions": [
          {
            "AttributeName": "cache_key",
            "AttributeType": "S"
          }
        ],
        "BillingMode": "PAY_PER_REQUEST",
        "SSESpecification": {
          "Enabled": true
        },
        "PointInTimeRecoveryEnabled": false,
        "Tags": {
          "Environment": "production"
        }
      }
    ]
  },
  "secretsmanager": {
    "secrets": [
      {
        "Name": "datavault/prod/database",
        "SecretString": "{\"username\":\"admin\",\"password\":\"MyPlaintextPassword123!\"}",
        "Tags": {
          "Environment": "production"
        }
      },
      {
        "Name": "datavault/prod/third-party-apis",
        "SecretString": "{\"stripe_key\":\"sk_live_xyz123\",\"sendgrid_key\":\"SG.plaintext.key\"}",
        "Tags": {
          "Environment": "production"
        }
      },
      {
        "Name": "datavault/legacy/old-db-creds",
        "SecretString": "legacy_admin:old_password_2021",
        "Tags": {
          "Environment": "legacy"
        }
      }
    ]
  },
  "sqs": {
    "queues": [
      {
        "QueueName": "datavault-processing-queue",
        "Attributes": {
          "VisibilityTimeout": "300"
        }
      },
      {
        "QueueName": "datavault-notifications",
        "Attributes": {
          "VisibilityTimeout": "60"
        }
      },
      {
        "QueueName": "datavault-dlq",
        "Attributes": {
          "VisibilityTimeout": "900"
        }
      }
    ]
  }
}