{
  "iam": {
    "roles": [
      {
        "RoleName": "PayFlow-Lambda-Execution-Role",
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "lambda.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "AttachedPolicies": ["PayFlow-Lambda-Basic-Policy"]
      },
      {
        "RoleName": "PayFlow-API-Lambda-Role",
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "lambda.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "AttachedPolicies": ["PayFlow-API-Overprivileged-Policy"]
      },
      {
        "RoleName": "PayFlow-EC2-Role",
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "ec2.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "AttachedPolicies": ["PayFlow-EC2-Access-Policy"]
      },
      {
        "RoleName": "PayFlow-Legacy-Admin-Role",
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "AWS": "*"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "AttachedPolicies": ["PayFlow-Admin-Everything-Policy"]
      }
    ],
    "policies": [
      {
        "PolicyName": "PayFlow-Lambda-Basic-Policy",
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Action": [
                "logs:CreateLogGroup",
                "logs:CreateLogStream",
                "logs:PutLogEvents"
              ],
              "Resource": "arn:aws:logs:*:*:*"
            },
            {
              "Effect": "Allow",
              "Action": [
                "dynamodb:GetItem",
                "dynamodb:PutItem",
                "dynamodb:UpdateItem"
              ],
              "Resource": "arn:aws:dynamodb:us-east-1:123456789012:table/payflow-transactions"
            }
          ]
        }
      },
      {
        "PolicyName": "PayFlow-API-Overprivileged-Policy",
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Action": "*",
              "Resource": "*"
            }
          ]
        }
      },
      {
        "PolicyName": "PayFlow-EC2-Access-Policy",
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Action": [
                "s3:GetObject",
                "s3:PutObject"
              ],
              "Resource": "arn:aws:s3:::payflow-documents/*"
            },
            {
              "Effect": "Allow",
              "Action": [
                "secretsmanager:GetSecretValue"
              ],
              "Resource": "arn:aws:secretsmanager:us-east-1:123456789012:secret:payflow-db-credentials*"
            }
          ]
        }
      },
      {
        "PolicyName": "PayFlow-Admin-Everything-Policy",
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Action": "*",
              "Resource": "*"
            }
          ]
        }
      }
    ],
    "users": [
      {
        "UserName": "payflow-ci-cd",
        "AttachedPolicies": ["PayFlow-Lambda-Basic-Policy"]
      },
      {
        "UserName": "sarah-founder",
        "AttachedPolicies": ["PayFlow-Admin-Everything-Policy"]
      },
      {
        "UserName": "mike-devops",
        "AttachedPolicies": ["PayFlow-EC2-Access-Policy"]
      }
    ]
  },
  "s3": {
    "buckets": [
      {
        "Name": "payflow-documents",
        "Versioning": "Enabled",
        "Encryption": "AES256",
        "PublicAccessBlock": {
          "BlockPublicAcls": true,
          "IgnorePublicAcls": true,
          "BlockPublicPolicy": true,
          "RestrictPublicBuckets": true
        }
      },
      {
        "Name": "payflow-transaction-logs",
        "Versioning": "Suspended",
        "Encryption": "SSE-S3",
        "PublicAccessBlock": {
          "BlockPublicAcls": true,
          "IgnorePublicAcls": true,
          "BlockPublicPolicy": true,
          "RestrictPublicBuckets": true
        }
      },
      {
        "Name": "payflow-backup-storage",
        "Versioning": "Enabled",
        "Encryption": "None",
        "PublicAccessBlock": {
          "BlockPublicAcls": true,
          "IgnorePublicAcls": true,
          "BlockPublicPolicy": true,
          "RestrictPublicBuckets": true
        }
      }
    ]
  },
  "ec2": {
    "instances": [
      {
        "InstanceId": "i-0a1b2c3d4e5f6g7h8",
        "InstanceType": "t3.large",
        "State": "running",
        "Tags": {
          "Name": "payflow-api-server-prod",
          "Environment": "production"
        }
      },
      {
        "InstanceId": "i-9i8h7g6f5e4d3c2b1",
        "InstanceType": "t3.medium",
        "State": "running",
        "Tags": {
          "Name": "payflow-worker-node",
          "Environment": "production"
        }
      },
      {
        "InstanceId": "i-1a2b3c4d5e6f7g8h9",
        "InstanceType": "t3.small",
        "State": "running",
        "Tags": {
          "Name": "payflow-dev-server",
          "Environment": "development"
        }
      }
    ],
    "security_groups": [
      {
        "GroupName": "payflow-web-sg",
        "Description": "Web server security group",
        "IngressRules": [
          {
            "IpProtocol": "tcp",
            "FromPort": 443,
            "ToPort": 443,
            "CidrBlocks": ["0.0.0.0/0"]
          },
          {
            "IpProtocol": "tcp",
            "FromPort": 80,
            "ToPort": 80,
            "CidrBlocks": ["0.0.0.0/0"]
          }
        ]
      },
      {
        "GroupName": "payflow-admin-sg",
        "Description": "Administrative access security group",
        "IngressRules": [
          {
            "IpProtocol": "tcp",
            "FromPort": 22,
            "ToPort": 22,
            "CidrBlocks": ["0.0.0.0/0"]
          }
        ]
      },
      {
        "GroupName": "payflow-database-sg",
        "Description": "Database access security group",
        "IngressRules": [
          {
            "IpProtocol": "tcp",
            "FromPort": 5432,
            "ToPort": 5432,
            "CidrBlocks": ["0.0.0.0/0"]
          }
        ]
      },
      {
        "GroupName": "payflow-dev-all-open",
        "Description": "Development environment - all ports open for testing",
        "IngressRules": [
          {
            "IpProtocol": "tcp",
            "FromPort": 0,
            "ToPort": 65535,
            "CidrBlocks": ["0.0.0.0/0"]
          }
        ]
      },
      {
        "GroupName": "payflow-internal-sg",
        "Description": "Internal service communication",
        "IngressRules": [
          {
            "IpProtocol": "tcp",
            "FromPort": 8080,
            "ToPort": 8080,
            "CidrBlocks": ["10.0.0.0/16"]
          }
        ]
      }
    ],
    "vpcs": [
      {
        "CidrBlock": "10.0.0.0/16",
        "Tags": {
          "Name": "payflow-main-vpc"
        }
      }
    ]
  },
  "lambda": {
    "functions": [
      {
        "FunctionName": "payflow-transaction-processor",
        "Runtime": "python3.11",
        "Handler": "index.handler",
        "MemorySize": 512,
        "Timeout": 30,
        "Role": "arn:aws:iam::123456789012:role/PayFlow-Lambda-Execution-Role",
        "Environment": {}
      },
      {
        "FunctionName": "payflow-api-gateway",
        "Runtime": "nodejs20.x",
        "Handler": "app.handler",
        "MemorySize": 256,
        "Timeout": 30,
        "Role": "arn:aws:iam::123456789012:role/PayFlow-API-Lambda-Role",
        "Environment": {}
      },
      {
        "FunctionName": "payflow-webhook-handler",
        "Runtime": "python3.9",
        "Handler": "webhook.handler",
        "MemorySize": 256,
        "Timeout": 15,
        "Role": "arn:aws:iam::123456789012:role/PayFlow-Lambda-Execution-Role",
        "Environment": {
          "DB_PASSWORD": "prod123!PayFlow",
          "API_SECRET": "sk_live_abc123def456ghi789"
        }
      },
      {
        "FunctionName": "payflow-fraud-detector",
        "Runtime": "python3.11",
        "Handler": "fraud.detect",
        "MemorySize": 1024,
        "Timeout": 60,
        "Role": "arn:aws:iam::123456789012:role/PayFlow-Lambda-Execution-Role",
        "Environment": {}
      }
    ]
  },
  "dynamodb": {
    "tables": [
      {
        "TableName": "payflow-transactions",
        "KeySchema": [
          {
            "AttributeName": "transaction_id",
            "KeyType": "HASH"
          }
        ],
        "AttributeDefinitions": [
          {
            "AttributeName": "transaction_id",
            "AttributeType": "S"
          }
        ],
        "BillingMode": "PAY_PER_REQUEST",
        "SSESpecification": {
          "Enabled": true
        },
        "PointInTimeRecoveryEnabled": true,
        "Tags": {
          "Environment": "production"
        }
      },
      {
        "TableName": "payflow-users",
        "KeySchema": [
          {
            "AttributeName": "user_id",
            "KeyType": "HASH"
          }
        ],
        "AttributeDefinitions": [
          {
            "AttributeName": "user_id",
            "AttributeType": "S"
          }
        ],
        "BillingMode": "PAY_PER_REQUEST",
        "SSESpecification": {
          "Enabled": false
        },
        "PointInTimeRecoveryEnabled": false,
        "Tags": {
          "Environment": "production"
        }
      },
      {
        "TableName": "payflow-audit-logs",
        "KeySchema": [
          {
            "AttributeName": "log_id",
            "KeyType": "HASH"
          }
        ],
        "AttributeDefinitions": [
          {
            "AttributeName": "log_id",
            "AttributeType": "S"
          }
        ],
        "BillingMode": "PAY_PER_REQUEST",
        "SSESpecification": {
          "Enabled": true
        },
        "PointInTimeRecoveryEnabled": true,
        "Tags": {
          "Environment": "production"
        }
      }
    ]
  },
  "secretsmanager": {
    "secrets": [
      {
        "Name": "payflow-db-credentials",
        "SecretString": "{\"username\":\"payflow_admin\",\"password\":\"SuperSecret123!\",\"host\":\"payflow-prod-cluster.us-east-1.amazonaws.com\"}",
        "Tags": {
          "Environment": "production"
        }
      },
      {
        "Name": "payflow-third-party-keys",
        "SecretString": "{\"stripe_key\":\"sk_live_xyz789\",\"plaid_secret\":\"abc123def456\"}",
        "Tags": {
          "Environment": "production"
        }
      }
    ]
  },
  "sqs": {
    "queues": [
      {
        "QueueName": "payflow-transaction-queue",
        "Attributes": {
          "VisibilityTimeout": "30"
        }
      },
      {
        "QueueName": "payflow-notification-queue",
        "Attributes": {
          "VisibilityTimeout": "60"
        }
      }
    ]
  }
}