{
  "iam": {
    "roles": [
      {
        "RoleName": "shipfast-lambda-execution-role",
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "lambda.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "AttachedPolicies": ["LambdaBasicExecutionPolicy"]
      },
      {
        "RoleName": "shipfast-ec2-role",
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "ec2.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "AttachedPolicies": ["EC2FullAccessPolicy"]
      },
      {
        "RoleName": "shipfast-developer-role",
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "AWS": "arn:aws:iam::123456789012:root"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "AttachedPolicies": ["DeveloperAccessPolicy"]
      }
    ],
    "policies": [
      {
        "PolicyName": "LambdaBasicExecutionPolicy",
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Action": [
                "logs:CreateLogGroup",
                "logs:CreateLogStream",
                "logs:PutLogEvents",
                "dynamodb:Query",
                "dynamodb:Scan",
                "dynamodb:PutItem",
                "dynamodb:UpdateItem"
              ],
              "Resource": "*"
            }
          ]
        }
      },
      {
        "PolicyName": "EC2FullAccessPolicy",
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Action": "*",
              "Resource": "*"
            }
          ]
        }
      },
      {
        "PolicyName": "DeveloperAccessPolicy",
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Action": [
                "s3:*",
                "lambda:*",
                "dynamodb:*",
                "ec2:*",
                "iam:*"
              ],
              "Resource": "*"
            }
          ]
        }
      }
    ],
    "users": [
      {
        "UserName": "shipfast-deploy-user",
        "AttachedPolicies": ["DeveloperAccessPolicy"]
      }
    ]
  },
  "s3": {
    "buckets": [
      {
        "Name": "shipfast-product-images",
        "Versioning": "Suspended",
        "Encryption": "None",
        "PublicAccessBlock": {
          "BlockPublicAcls": false,
          "IgnorePublicAcls": false,
          "BlockPublicPolicy": false,
          "RestrictPublicBuckets": false
        }
      },
      {
        "Name": "shipfast-user-uploads",
        "Versioning": "Enabled",
        "Encryption": "AES256",
        "PublicAccessBlock": {
          "BlockPublicAcls": true,
          "IgnorePublicAcls": true,
          "BlockPublicPolicy": true,
          "RestrictPublicBuckets": true
        }
      },
      {
        "Name": "shipfast-backups",
        "Versioning": "Suspended",
        "Encryption": "SSE-S3",
        "PublicAccessBlock": {
          "BlockPublicAcls": true,
          "IgnorePublicAcls": true,
          "BlockPublicPolicy": true,
          "RestrictPublicBuckets": true
        }
      },
      {
        "Name": "shipfast-analytics-data",
        "Versioning": "Enabled",
        "Encryption": "SSE-S3",
        "PublicAccessBlock": {
          "BlockPublicAcls": true,
          "IgnorePublicAcls": true,
          "BlockPublicPolicy": true,
          "RestrictPublicBuckets": true
        }
      }
    ]
  },
  "ec2": {
    "instances": [
      {
        "InstanceId": "i-0abc123def456789a",
        "InstanceType": "t3.large",
        "State": "running",
        "Tags": {
          "Name": "shipfast-web-prod",
          "Environment": "production",
          "Owner": "platform-team"
        }
      },
      {
        "InstanceId": "i-0def456abc789012b",
        "InstanceType": "t3.medium",
        "State": "running",
        "Tags": {
          "Name": "shipfast-api-prod",
          "Environment": "production",
          "Owner": "backend-team"
        }
      },
      {
        "InstanceId": "i-0789012abc345def6",
        "InstanceType": "t3.small",
        "State": "stopped",
        "Tags": {
          "Name": "shipfast-dev-test",
          "Environment": "development"
        }
      },
      {
        "InstanceId": "i-0345def789012abc7",
        "InstanceType": "t3.medium",
        "State": "running",
        "Tags": {
          "Name": "shipfast-staging",
          "Environment": "staging",
          "Owner": "qa-team"
        }
      }
    ],
    "security_groups": [
      {
        "GroupName": "shipfast-web-sg",
        "Description": "Security group for web servers",
        "IngressRules": [
          {
            "IpProtocol": "tcp",
            "FromPort": 443,
            "ToPort": 443,
            "CidrBlocks": ["0.0.0.0/0"]
          },
          {
            "IpProtocol": "tcp",
            "FromPort": 80,
            "ToPort": 80,
            "CidrBlocks": ["0.0.0.0/0"]
          }
        ]
      },
      {
        "GroupName": "shipfast-database-sg",
        "Description": "Security group for database access",
        "IngressRules": [
          {
            "IpProtocol": "tcp",
            "FromPort": 5432,
            "ToPort": 5432,
            "CidrBlocks": ["0.0.0.0/0"]
          }
        ]
      },
      {
        "GroupName": "shipfast-dev-sg",
        "Description": "Development security group - all access",
        "IngressRules": [
          {
            "IpProtocol": "tcp",
            "FromPort": 0,
            "ToPort": 65535,
            "CidrBlocks": ["0.0.0.0/0"]
          }
        ]
      },
      {
        "GroupName": "shipfast-ssh-sg",
        "Description": "SSH access for emergency debugging",
        "IngressRules": [
          {
            "IpProtocol": "tcp",
            "FromPort": 22,
            "ToPort": 22,
            "CidrBlocks": ["0.0.0.0/0"]
          }
        ]
      }
    ],
    "vpcs": [
      {
        "CidrBlock": "10.0.0.0/16",
        "Tags": {
          "Name": "shipfast-main-vpc"
        }
      }
    ]
  },
  "lambda": {
    "functions": [
      {
        "FunctionName": "shipfast-order-processor",
        "Runtime": "python3.11",
        "Handler": "index.handler",
        "MemorySize": 512,
        "Timeout": 30,
        "Role": "arn:aws:iam::123456789012:role/shipfast-lambda-execution-role",
        "Environment": {
          "DB_HOST": "prod-db.shipfast.com",
          "DB_USER": "admin",
          "DB_PASSWORD": "ShipFast2023!",
          "STRIPE_API_KEY": "sk_live_51234567890abcdef",
          "JWT_SECRET": "super-secret-key-123"
        }
      },
      {
        "FunctionName": "shipfast-email-sender",
        "Runtime": "nodejs20.x",
        "Handler": "index.handler",
        "MemorySize": 256,
        "Timeout": 15,
        "Role": "arn:aws:iam::123456789012:role/shipfast-lambda-execution-role",
        "Environment": {
          "SENDGRID_API_KEY": "SG.abc123def456.xyz789"
        }
      },
      {
        "FunctionName": "shipfast-image-resizer",
        "Runtime": "python3.9",
        "Handler": "handler.main",
        "MemorySize": 1024,
        "Timeout": 60,
        "Role": "arn:aws:iam::123456789012:role/shipfast-lambda-execution-role",
        "Environment": {}
      },
      {
        "FunctionName": "shipfast-legacy-migrator",
        "Runtime": "python3.9",
        "Handler": "migrate.handler",
        "MemorySize": 256,
        "Timeout": 30,
        "Role": "arn:aws:iam::123456789012:role/shipfast-lambda-execution-role",
        "Environment": {}
      }
    ]
  },
  "dynamodb": {
    "tables": [
      {
        "TableName": "shipfast-orders",
        "KeySchema": [
          {
            "AttributeName": "order_id",
            "KeyType": "HASH"
          }
        ],
        "AttributeDefinitions": [
          {
            "AttributeName": "order_id",
            "AttributeType": "S"
          }
        ],
        "BillingMode": "PAY_PER_REQUEST",
        "SSESpecification": {
          "Enabled": true
        },
        "PointInTimeRecoveryEnabled": true,
        "Tags": {
          "Environment": "production",
          "Owner": "backend-team"
        }
      },
      {
        "TableName": "shipfast-users",
        "KeySchema": [
          {
            "AttributeName": "user_id",
            "KeyType": "HASH"
          }
        ],
        "AttributeDefinitions": [
          {
            "AttributeName": "user_id",
            "AttributeType": "S"
          }
        ],
        "BillingMode": "PAY_PER_REQUEST",
        "SSESpecification": {
          "Enabled": false
        },
        "PointInTimeRecoveryEnabled": false,
        "Tags": {
          "Environment": "production"
        }
      },
      {
        "TableName": "shipfast-products",
        "KeySchema": [
          {
            "AttributeName": "product_id",
            "KeyType": "HASH"
          }
        ],
        "AttributeDefinitions": [
          {
            "AttributeName": "product_id",
            "AttributeType": "S"
          }
        ],
        "BillingMode": "PAY_PER_REQUEST",
        "SSESpecification": {
          "Enabled": true
        },
        "PointInTimeRecoveryEnabled": true,
        "Tags": {
          "Environment": "production",
          "Owner": "product-team"
        }
      }
    ]
  },
  "secretsmanager": {
    "secrets": [
      {
        "Name": "shipfast/prod/database",
        "SecretString": "{\"username\":\"admin\",\"password\":\"ProductionDB2024!\"}",
        "Tags": {
          "Environment": "production"
        }
      },
      {
        "Name": "shipfast/stripe/webhook",
        "SecretString": "whsec_1234567890abcdefghijklmnopqrstuvwxyz",
        "Tags": {
          "Environment": "production"
        }
      }
    ]
  },
  "sqs": {
    "queues": [
      {
        "QueueName": "shipfast-order-queue",
        "Attributes": {
          "VisibilityTimeout": "30"
        }
      },
      {
        "QueueName": "shipfast-email-queue",
        "Attributes": {
          "VisibilityTimeout": "60"
        }
      }
    ]
  }
}