{
  "iam": {
    "roles": [
      {
        "RoleName": "QuickCartProductionECS",
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "ec2.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "AttachedPolicies": ["QuickCartFullAccess"]
      },
      {
        "RoleName": "QuickCartLambdaExecution",
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "lambda.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "AttachedPolicies": ["QuickCartLambdaPolicy"]
      },
      {
        "RoleName": "QuickCartCrossAccountAdmin",
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "AWS": "*"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "AttachedPolicies": ["QuickCartAdminPolicy"]
      },
      {
        "RoleName": "QuickCartAnalyticsReadOnly",
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "lambda.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "AttachedPolicies": ["QuickCartReadOnlyPolicy"]
      }
    ],
    "policies": [
      {
        "PolicyName": "QuickCartFullAccess",
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Action": "*",
              "Resource": "*"
            }
          ]
        }
      },
      {
        "PolicyName": "QuickCartLambdaPolicy",
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Action": [
                "dynamodb:*",
                "s3:*",
                "logs:CreateLogGroup",
                "logs:CreateLogStream",
                "logs:PutLogEvents"
              ],
              "Resource": "*"
            }
          ]
        }
      },
      {
        "PolicyName": "QuickCartAdminPolicy",
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Action": "*",
              "Resource": "*"
            }
          ]
        }
      },
      {
        "PolicyName": "QuickCartReadOnlyPolicy",
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Action": [
                "dynamodb:Query",
                "dynamodb:GetItem",
                "s3:GetObject"
              ],
              "Resource": [
                "arn:aws:dynamodb:*:*:table/quickcart-*",
                "arn:aws:s3:::quickcart-*/*"
              ]
            }
          ]
        }
      }
    ],
    "users": [
      {
        "UserName": "quickcart-deploy",
        "AttachedPolicies": ["QuickCartFullAccess"]
      },
      {
        "UserName": "quickcart-legacy-admin",
        "AttachedPolicies": ["QuickCartAdminPolicy"]
      }
    ]
  },
  "s3": {
    "buckets": [
      {
        "Name": "quickcart-customer-uploads",
        "Versioning": "Suspended",
        "Encryption": "None",
        "PublicAccessBlock": {
          "BlockPublicAcls": false,
          "IgnorePublicAcls": false,
          "BlockPublicPolicy": false,
          "RestrictPublicBuckets": false
        }
      },
      {
        "Name": "quickcart-product-images",
        "Versioning": "Enabled",
        "Encryption": "AES256",
        "PublicAccessBlock": {
          "BlockPublicAcls": true,
          "IgnorePublicAcls": true,
          "BlockPublicPolicy": true,
          "RestrictPublicBuckets": true
        }
      },
      {
        "Name": "quickcart-backups-production",
        "Versioning": "Enabled",
        "Encryption": "SSE-S3",
        "PublicAccessBlock": {
          "BlockPublicAcls": true,
          "IgnorePublicAcls": true,
          "BlockPublicPolicy": true,
          "RestrictPublicBuckets": true
        }
      },
      {
        "Name": "quickcart-analytics-raw",
        "Versioning": "Suspended",
        "Encryption": "AES256",
        "PublicAccessBlock": {
          "BlockPublicAcls": true,
          "IgnorePublicAcls": true,
          "BlockPublicPolicy": true,
          "RestrictPublicBuckets": true
        }
      }
    ]
  },
