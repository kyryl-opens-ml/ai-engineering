    "security_groups": [
      {
        "GroupName": "quickcart-web-sg",
        "Description": "Web tier security group",
        "IngressRules": [
          {
            "IpProtocol": "tcp",
            "FromPort": 80,
            "ToPort": 80,
            "CidrBlocks": ["0.0.0.0/0"]
          },
          {
            "IpProtocol": "tcp",
            "FromPort": 443,
            "ToPort": 443,
            "CidrBlocks": ["0.0.0.0/0"]
          }
        ]
      },
      {
        "GroupName": "quickcart-dev-all-open",
        "Description": "Development environment - all access",
        "IngressRules": [
          {
            "IpProtocol": "-1",
            "FromPort": -1,
            "ToPort": -1,
            "CidrBlocks": ["0.0.0.0/0"]
          }
        ]
      },
      {
        "GroupName": "quickcart-ssh-access",
        "Description": "SSH access for debugging",
        "IngressRules": [
          {
            "IpProtocol": "tcp",
            "FromPort": 22,
            "ToPort": 22,
            "CidrBlocks": ["0.0.0.0/0"]
          }
        ]
      },
      {
        "GroupName": "quickcart-database-sg",
        "Description": "Database security group",
        "IngressRules": [
          {
            "IpProtocol": "tcp",
            "FromPort": 5432,
            "ToPort": 5432,
            "CidrBlocks": ["0.0.0.0/0"]
          }
        ]
      },
      {
        "GroupName": "quickcart-api-sg",
        "Description": "API security group",
        "IngressRules": [
          {
            "IpProtocol": "tcp",
            "FromPort": 8080,
            "ToPort": 8080,
            "CidrBlocks": ["10.0.0.0/16"]
          },
          {
            "IpProtocol": "tcp",
            "FromPort": 443,
            "ToPort": 443,
            "CidrBlocks": ["0.0.0.0/0"]
          }
        ]
      }
    ],
    "vpcs": [
      {
        "CidrBlock": "10.0.0.0/16",
        "Tags": {
          "Name": "quickcart-production-vpc"
        }
      },
      {
        "CidrBlock": "10.1.0.0/16",
        "Tags": {
          "Name": "quickcart-staging-vpc"
        }
      }
    ]
  },
  "lambda": {
    "functions": [
      {
        "FunctionName": "quickcart-order-processor",
        "Runtime": "python3.11",
        "Handler": "handler.process_order",
        "MemorySize": 512,
        "Timeout": 30,
        "Role": "arn:aws:iam::123456789012:role/QuickCartLambdaExecution",
        "Environment": {
          "DB_HOST": "quickcart-prod.cluster-abc123.us-east-1.rds.amazonaws.com",
          "DB_PASSWORD": "SuperSecret123!",
          "STRIPE_SECRET_KEY": "sk_live_51abc123def456ghi789jkl",
          "JWT_SECRET": "my-super-secret-key-2019"
        }
      },
      {
        "FunctionName": "quickcart-email-sender",
        "Runtime": "nodejs18.x",
        "Handler": "index.handler",
        "MemorySize": 128,
        "Timeout": 300,
        "Role": "arn:aws:iam::123456789012:role/QuickCartLambdaExecution",
        "Environment": {
          "SES_REGION": "us-east-1",
          "FROM_EMAIL": "noreply@quickcart.com"
        }
      },
      {
        "FunctionName": "quickcart-inventory-sync",
        "Runtime": "python3.9",
        "Handler": "sync.handler",
        "MemorySize": 256,
        "Timeout": 900,
        "Role": "arn:aws:iam::123456789012:role/QuickCartLambdaExecution",
        "Environment": {
          "WAREHOUSE_API_KEY": "wh_live_abc123def456",
          "INVENTORY_TABLE": "quickcart-inventory-prod"
        }
      },
      {
        "FunctionName": "quickcart-legacy-reports",
        "Runtime": "python3.9",
        "Handler": "reports.generate",
        "MemorySize": 1024,
        "Timeout": 900,
        "Role": "arn:aws:iam::123456789012:role/QuickCartAnalyticsReadOnly",
        "Environment": {
          "REPORT_BUCKET": "quickcart-analytics-raw"
        }
      },
      {
        "FunctionName": "quickcart-data-migration",
        "Runtime": "python3.11",
        "Handler": "migrate.handler",
        "MemorySize": 2048,
        "Timeout": 900,
        "Role": "arn:aws:iam::123456789012:role/QuickCartLambdaExecution",
        "Environment": {}
      }
    ]
  },
